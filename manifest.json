{
  "manifest_version": 3,
  "name": "Archive Lookup",
  "version": "1.0",
  "description": "Find archived versions of articles behind paywalls",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "https://archive.today/*",
    "https://archive.is/*",
    "https://archive.md/*",
    "https://archive.ph/*"
  ],
  "optional_host_permissions": ["*://*/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "archive_headers",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
